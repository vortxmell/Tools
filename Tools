-- Parse args editor text → table of Lua values
local function parseArgsEditor()
    local result = {}
    for line in argsEditor.Text:gmatch("[^\n]+") do
        line = line:match("^%s*(.-)%s*$") -- trim
        if line == "" or line:sub(1,2) == "--" then
            -- skip empty lines and comments
        elseif line == "true" then
            table.insert(result, true)
        elseif line == "false" then
            table.insert(result, false)
        elseif tonumber(line) then
            table.insert(result, tonumber(line))
        elseif line:sub(1,1) == '"' and line:sub(-1) == '"' then
            -- strip surrounding quotes, unescape
            table.insert(result, line:sub(2,-2):gsub('\\"', '"'))
        else
            -- raw string fallback
            table.insert(result, line)
        end
    end
    return result
end

-- Fire remote dengan parsed args
local function fireRemote(log, args)
    if not log then return false, "No remote selected" end

    -- Walk path terus tanpa pcall scope issue
    local parts = {}
    for p in log.path:gmatch("[^%.]+") do
        table.insert(parts, p)
    end

    local obj
    local walkOk, walkErr = pcall(function()
        obj = game:GetService(parts[1])
        for i = 2, #parts do
            local child = obj:FindFirstChild(parts[i])
            if not child then
                -- Cuba WaitForChild sekali dengan timeout pendek
                child = obj:WaitForChild(parts[i], 2)
            end
            if not child then
                error("Cannot find: "..parts[i])
            end
            obj = child
        end
    end)

    if not walkOk or not obj then
        return false, tostring(walkErr)
    end

    -- Fire terus, unpack args
    local fireOk, fireErr = pcall(function()
        if #args == 0 then
            obj:FireServer()
        elseif #args == 1 then
            obj:FireServer(args[1])
        elseif #args == 2 then
            obj:FireServer(args[1], args[2])
        elseif #args == 3 then
            obj:FireServer(args[1], args[2], args[3])
        elseif #args == 4 then
            obj:FireServer(args[1], args[2], args[3], args[4])
        else
            obj:FireServer(table.unpack(args))
        end
    end)

    return fireOk, fireErr
end

