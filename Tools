local function mkFrame(parent, size, pos, color, radius)
    local f = Instance.new("Frame")
    f.Size = size
    f.Position = pos or UDim2.new(0,0,0,0)
    f.BackgroundColor3 = color or C.panel
    f.BorderSizePixel = 0
    f.Parent = parent
    if radius then
        Instance.new("UICorner", f).CornerRadius = UDim.new(0, radius)
    end
    return f
end

local function mkLabel(parent, text, size, pos, textColor, fontSize, font, xAlign)
    local l = Instance.new("TextLabel")
    l.Size = size
    l.Position = pos or UDim2.new(0,0,0,0)
    l.BackgroundTransparency = 1
    l.Text = text
    l.TextColor3 = textColor or C.goldText
    l.TextSize = fontSize or 12
    l.Font = font or Enum.Font.Gotham
    l.TextXAlignment = xAlign or Enum.TextXAlignment.Left
    l.TextTruncate = Enum.TextTruncate.AtEnd
    l.Parent = parent
    return l
end

local function mkBtn(parent, text, size, pos, bgColor, textColor, fontSize)
    local b = Instance.new("TextButton")
    b.Size = size
    b.Position = pos or UDim2.new(0,0,0,0)
    b.BackgroundColor3 = bgColor or C.gold
    b.BorderSizePixel = 0
    b.Text = text
    b.TextColor3 = textColor or C.bg
    b.TextSize = fontSize or 12
    b.Font = Enum.Font.GothamBold
    b.AutoButtonColor = true
    b.Parent = parent
    Instance.new("UICorner", b).CornerRadius = UDim.new(0, 5)
    return b
end

local function mkInput(parent, placeholder, size, pos)
    local box = Instance.new("TextBox")
    box.Size = size
    box.Position = pos or UDim2.new(0,0,0,0)
    box.BackgroundColor3 = C.panelDark
    box.BorderSizePixel = 0
    box.Text = ""
    box.PlaceholderText = placeholder or ""
    box.TextColor3 = C.goldText
    box.PlaceholderColor3 = C.dim
    box.TextSize = 11
    box.Font = Enum.Font.Gotham
    box.TextXAlignment = Enum.TextXAlignment.Left
    box.ClearTextOnFocus = false
    box.Parent = parent
    Instance.new("UICorner", box).CornerRadius = UDim.new(0, 5)
    local pad = Instance.new("UIPadding", box)
    pad.PaddingLeft = UDim.new(0, 6)
    return box
end

local function mkScroll(parent, size, pos)
    local s = Instance.new("ScrollingFrame")
    s.Size = size
    s.Position = pos or UDim2.new(0,0,0,0)
    s.BackgroundColor3 = C.panelDark
    s.BorderSizePixel = 0
    s.ScrollBarThickness = 4
    s.ScrollBarImageColor3 = C.gold
    s.CanvasSize = UDim2.new(0,0,0,0)
    s.AutomaticCanvasSize = Enum.AutomaticSize.Y
    s.Parent = parent
    Instance.new("UICorner", s).CornerRadius = UDim.new(0, 5)
    local layout = Instance.new("UIListLayout", s)
    layout.SortOrder = Enum.SortOrder.LayoutOrder
    layout.Padding = UDim.new(0, 1)
    return s, layout
end

local function mkStroke(parent, color, thickness)
    local s = Instance.new("UIStroke", parent)
    s.Color = color or C.gold
    s.Thickness = thickness or 1
    return s
end

local function mkTitle(parent, text, height)
    local bar = mkFrame(parent,
        UDim2.new(1,0,0,height or 32),
        UDim2.new(0,0,0,0), C.gold, 7)
