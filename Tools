local function addRspyLog(dir, name, path, args)
    if paused then return end
    -- Direction filter
    if dirFilter == "cs" and dir ~= "C>S" then return end
    if dirFilter == "sc" and dir ~= "S>C" then return end
    local filter = rspySearch.Text:lower()
    if filter~="" and not name:lower():find(filter,1,true) then return end

    remoteCount[path] = (remoteCount[path] or 0)+1
    local isBuf   = hasBuffer(args)
    local argsStr = describeArgs(args)
    local ts      = os.date("%M:%S")
    local now     = os.clock()

    -- Cooldown: kira ms dari last fire remote yang sama
    local intervalMs = nil
    if remoteLastFire[path] then
        intervalMs = math.floor((now - remoteLastFire[path]) * 1000)
    end
    remoteLastFire[path] = now

    local entry = {
        dir=dir, name=name, path=path,
        args=args, argsStr=argsStr,
        isBuf=isBuf, time=ts,
