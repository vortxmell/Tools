local function parseArgsEditor()
    local result={}
    for line in argsEditor.Text:gmatch("[^\n]+") do
        line = line:match("^%s*(.-)%s*$")
        if line~="" and line:sub(1,2)~="--" then
            if line=="true" then table.insert(result,true)
            elseif line=="false" then table.insert(result,false)
            elseif tonumber(line) then table.insert(result,tonumber(line))
            elseif line:sub(1,1)=='"' and line:sub(-1)=='"' then
                table.insert(result,(line:sub(2,-2):gsub('\\"','"')))
            else table.insert(result,line) end
        end
    end
    return result
end

local function fireRemote(log, args)
    if not log then return false,"No remote selected" end
    local chain = buildChain(log.path)
    if not chain then return false,"Invalid path" end
    local argParts={}
    for _,v in ipairs(args) do
        local t=type(v)
        if t=="string" then table.insert(argParts,string.format("%q",v))
        elseif t=="number" or t=="boolean" then table.insert(argParts,tostring(v))
        else table.insert(argParts,string.format("%q",tostring(v))) end
    end
    local fn,err = loadstring(chain..":FireServer("..table.concat(argParts,", ")..")")
    if not fn then return false,"loadstring: "..tostring(err) end
    local ok,ferr = pcall(fn)
    -- Log ke rSpy selepas fire (bypass rspyVisible check tak perlu — hook akan catch)
    return ok,ferr
end

