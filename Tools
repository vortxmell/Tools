-- ================================================
-- SECURITY: Auto-clear on anti-cheat scan detection
-- Detect bila game script cuba iterate PlayerGui
-- atau scan descendants — clear logs immediately
-- ================================================
local function setupAntiScan()
    -- Monitor PlayerGui children access
    -- Kalau game script buat GetChildren/GetDescendants pada PlayerGui,
    -- kemungkinan anti-cheat scan — clear rSpy logs
    if not hookmetamethod then return end

    local scanCount = 0
    local lastScan  = 0

    -- Hook __namecall untuk detect GetChildren/GetDescendants calls pada pgui
    local origScanHook = nil
    origScanHook = hookmetamethod(game, "__namecall", newcclosure and newcclosure(function(self, ...)
        local method = getnamecallmethod()
        local result = origScanHook(self, ...)

        -- Detect kalau game scan PlayerGui atau CoreGui
        if (method == "GetChildren" or method == "GetDescendants")
        and (self == pgui or self == game:GetService("CoreGui")) then
            local now = os.clock()
            -- Multiple scans dalam masa singkat = suspicious
            if now - lastScan < 2 then
                scanCount += 1
                if scanCount >= 3 then
                    -- Possible anti-cheat scan — clear logs
                    remoteLogs={}; remoteCount={}
                    for _,c in pairs(rspyScroll:GetChildren()) do
                        if c:IsA("Frame") then c:Destroy() end
                    end
                    rspyCount.Text = "0 events"
                    scanCount = 0
                    addConLog("⚠ Possible AC scan detected — logs cleared", C.orange,"[sec]")
                end
            else
                scanCount = 1
            end
            lastScan = now
        end

        return result
    end) or function(self, ...)
        return origScanHook(self, ...)
    end)
end

pcall(setupAntiScan)

