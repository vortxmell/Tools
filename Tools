local function loadTool(url, statusLabel, btn, originalText)
    statusLabel.Text      = "⏳ Loading..."
    statusLabel.TextColor3 = C.goldText
    btn.Text              = "Loading..."
    btn.BackgroundColor3  = C.dimDark

    task.spawn(function()
        local ok, err = pcall(function()
            local src = game:HttpGet(url)
            local fn, lerr = loadstring(src)
            if not fn then error(lerr) end
            fn()
        end)
        if ok then
            statusLabel.Text       = "✓ Loaded!"
            statusLabel.TextColor3 = C.green
            btn.Text               = "✓ Done"
            btn.BackgroundColor3   = C.green
            addConLog("Tool loaded: "..url:match("([^/]+)$"), C.green,"[tools]")
        else
            statusLabel.Text       = "✗ "..(tostring(err):sub(1,40))
            statusLabel.TextColor3 = C.red
            btn.Text               = originalText
            btn.BackgroundColor3   = C.dimDark
            addConLog("Tool error: "..tostring(err), C.red,"[tools]")
        end
    end)
end

