-- ================================================
-- HOOK ALL REMOTES
-- hookmetamethod(__namecall) dengan cara betul:
-- 1. Capture args {...} DULU sebelum panggil orig
-- 2. checkcaller() — skip kalau script kita sendiri
--    yang fire (elak infinite loop)
-- 3. Original call tanpa pcall — zero interference
-- 4. Log via task.defer — async, lepas game fire
-- ================================================
local hookOrig = nil

local function startHook()
    if not hookmetamethod then
        addConLog("hookmetamethod tidak tersedia!", C.red, "[err]")
        return
    end

    hookOrig = hookmetamethod(game, "__namecall", function(self, ...)
        local method = getnamecallmethod()

        -- Capture args SEBELUM panggil original
        -- (lepas call, vararg dah invalid dalam beberapa executor)
        local args = {...}

        -- Panggil original DULU — zero delay, no pcall wrapper
        local result = hookOrig(self, ...)

        -- Skip kalau bukan remote call yang kita nak
        if not checkcaller()
        and (method == "FireServer"
          or method == "InvokeServer"
          or method == "FireUnreliableServer") then
            if not paused then
                local name = self.Name
                local ok, path = pcall(function() return self:GetFullName() end)
                if ok then
                    task.defer(function()
                        if not paused then
                            pcall(addRspyLog, "C>S", name, path, args)
                        end
                    end)
                end
            end
        end

        return result
    end)

    -- S>C via OnClientEvent
    local function connectRE(v)
        if v:IsA("RemoteEvent") then
            v.OnClientEvent:Connect(function(...)
                if paused then return end
                local args = {...}
                local path = ""
                pcall(function() path = v:GetFullName() end)
                task.defer(function()
                    if not paused then
                        pcall(addRspyLog, "S>C", v.Name, path, args)
                    end
                end)
            end)
        end
    end

    for _,v in pairs(game:GetDescendants()) do pcall(connectRE, v) end
    game.DescendantAdded:Connect(function(v)
        task.wait()
        pcall(connectRE, v)
    end)

    addConLog("Hook aktif! Semua remote dimonitor.", C.green, "[sys]")
    addConLog("C>S: namecall hook | S>C: OnClientEvent", C.dim, "[sys]")
end

startHook()

