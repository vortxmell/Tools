-- ================================================
-- HELPER FUNCTIONS
-- ================================================
local function getTime()
    local t = os.clock()
    local s = math.floor(t) % 60
    local m = math.floor(t / 60) % 60
    return string.format("%02d:%02d", m, s)
end

local function describeValue(v)
    local t = type(v)
    if t == "buffer" then
        local len = buffer.len(v)
        local hex = {}
        for i = 0, math.min(len-1, 8) do
            table.insert(hex, string.format("%02X", buffer.readu8(v, i)))
        end
        return string.format("<buf:%db>[%s%s]", len,
            table.concat(hex, " "),
            len > 9 and "..." or "")
    elseif t == "Instance" then
        return "["..v.ClassName.."] "..v:GetFullName()
    elseif t == "Vector3" then
        return string.format("Vec3(%.1f,%.1f,%.1f)", v.X, v.Y, v.Z)
    elseif t == "CFrame" then
        return string.format("CF(%.1f,%.1f,%.1f)", v.X, v.Y, v.Z)
    elseif t == "table" then
        local parts = {}
        local count = 0
        for k, val in pairs(v) do
            count += 1
            if count <= 4 then
                table.insert(parts, tostring(k).."="..tostring(val))
            end
        end
        return "{"..table.concat(parts, ", ")..(count > 4 and "..." or).."}"
    else
        return tostring(v)
    end
end

local function describeArgs(args)
    if #args == 0 then return "(no args)" end
    local parts = {}
    for _, v in ipairs(args) do
        table.insert(parts, describeValue(v))
    end
    return table.concat(parts, ", ")
end

local function hasBuffer(args)
    for _, v in ipairs(args) do
        if type(v) == "buffer" then return true end
    end
    return false
end

local function getHexFull(args)
    local result = {}
    for i, v in ipairs(args) do
        if type(v) == "buffer" then
            local len = buffer.len(v)
            local hex = {}
            local asc = {}
            for j = 0, len-1 do
                local b = buffer.readu8(v, j)
                table.insert(hex, string.format("%02X", b))
                table.insert(asc, (b >= 32 and b <= 126) and string.char(b) or ".")
            end
            table.insert(result, string.format(
                "[Arg%d Buffer %db]\nHEX: %s\nASC: %s",
                i, len,
                table.concat(hex, " "),
                table.concat(asc, "")
            ))
        else
            table.insert(result, "[Arg"..i.."] "..tostring(v))
        end
    end
    return table.concat(result, "\n")
end

