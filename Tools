local kbBaseY  = nil
local kbActive = false
local cam      = workspace.CurrentCamera
local lastVpH  = cam.ViewportSize.Y

cam:GetPropertyChangedSignal("ViewportSize"):Connect(function()
    local newH = cam.ViewportSize.Y
    local diff = lastVpH - newH

    if diff > 100 and not kbActive then
        kbActive = true
        local absX = mainWin.AbsolutePosition.X
        local absY = mainWin.AbsolutePosition.Y
        kbBaseY = absY
        local newY = math.max(5, absY - diff)
        mainWin.Position = UDim2.new(0, absX, 0, newY)
    elseif diff < -100 and kbActive then
        kbActive = false
        if kbBaseY then
            local absX = mainWin.AbsolutePosition.X
            mainWin.Position = UDim2.new(0, absX, 0, kbBaseY)
            kbBaseY = nil
        end
    end

    lastVpH = newH
end)

