-- ── _G.fire() — quick fire remote dari console ──
-- Usage: _G.fire("RemoteName", arg1, arg2, ...)
-- atau:  _G.fire("Full.Path.To.Remote", arg1, arg2)
_G.fire = function(nameOrPath, ...)
    local args = {...}
    -- Cuba find remote by full path dulu, then by name
    local remote = nil
    local path = nameOrPath

    -- Check sama ada full path atau name je
    if nameOrPath:find("%.") then
        -- Full path — walk descendants
        local parts = {}
        for p in nameOrPath:gmatch("[^%.]+") do table.insert(parts, p) end
        local ok, obj = pcall(function()
            local o = game:GetService(parts[1])
            for i=2,#parts do o = o:FindFirstChild(parts[i]) end
            return o
        end)
        if ok and obj then remote = obj end
    else
        -- Name je — search dalam game descendants
        local ok, obj = pcall(function()
            return game:GetDescendants()
        end)
        if ok then
            for _, v in ipairs(obj) do
                if (v:IsA("RemoteEvent") or v:IsA("RemoteFunction") or v:IsA("UnreliableRemoteEvent"))
                and v.Name == nameOrPath then
                    remote = v; break
                end
            end
        end
    end

    if not remote then
        addConLog("fire: remote '"..nameOrPath.."' tidak dijumpai", C.red,"[fire]")
        return false
    end

    -- Fire ikut class
    local fireOk, fireErr
    if remote:IsA("RemoteFunction") then
        fireOk, fireErr = pcall(function() return remote:InvokeServer(table.unpack(args)) end)
    elseif remote:IsA("UnreliableRemoteEvent") then
        fireOk, fireErr = pcall(function() remote:FireUnreliableServer(table.unpack(args)) end)
    else
        fireOk, fireErr = pcall(function() remote:FireServer(table.unpack(args)) end)
    end

    if fireOk then
        addConLog("fire: "..remote:GetFullName().." ✓", C.green,"[fire]")
    else
        addConLog("fire error: "..tostring(fireErr), C.red,"[fire]")
    end
    return fireOk
end

