-- ================================================
-- rSPY LOG ENTRY BUILDER
-- ================================================
local function addRspyLog(direction, remoteName, remotePath, args, rawBuf)
    if paused then return end
    if blockedRemotes[remotePath] then return end

    -- Filter check
    local filter = rspySearch.Text:lower()
    local nameMatch = remoteName:lower():find(filter, 1, true)
    if filter ~= "" and not nameMatch then return end

    remoteCount[remotePath] = (remoteCount[remotePath] or 0) + 1

    local isBuf = hasBuffer(args)
    local argsStr = describeArgs(args)
    local timestamp = getTime()

    local entry = {
        direction = direction,
        name = remoteName,
        path = remotePath,
        args = args,
        argsStr = argsStr,
        isBuf = isBuf,
        time = timestamp,
        count = remoteCount[remotePath],
        rawBuf = rawBuf,
    }
    table.insert(remoteLogs, 1, entry)
    if #remoteLogs > maxLogs then
        table.remove(remoteLogs, #remoteLogs)
    end

    -- Color by direction
    local dirColor = direction == "C→S" and C.orange
        or direction == "S→C" and C.blue
        or C.purple

    local row = Instance.new("Frame")
    row.Size = UDim2.new(1,-4,0,30)
    row.BackgroundColor3 = C.panel
    row.BorderSizePixel = 0
    row.LayoutOrder = #rspyScroll:GetChildren()
    row.Parent = rspyScroll
    Instance.new("UICorner", row).CornerRadius = UDim.new(0,3)

    -- Direction tag
    local dirTag = mkFrame(row, UDim2.new(0,32,0,18),
        UDim2.new(0,3,0,6), dirColor, 3)
    mkLabel(dirTag, direction,
        UDim2.new(1,0,1,0),
        UDim2.new(0,0,0,0),
        C.bg, 9, Enum.Font.GothamBold,
        Enum.TextXAlignment.Center)

    -- Buffer indicator
    if isBuf then
        local bufTag = mkFrame(row, UDim2.new(0,24,0,14),
            UDim2.new(0,38,0,8), C.purple, 3)
        mkLabel(bufTag, "buf",
            UDim2.new(1,0,1,0),
            UDim2.new(0,0,0,0),
            C.white, 8, Enum.Font.GothamBold,
            Enum.TextXAlignment.Center)
    end

    local nameX = isBuf and 66 or 38

    -- Remote name
    mkLabel(row, remoteName,
        UDim2.new(0,120,0,16),
        UDim2.new(0,nameX,0,2),
        C.goldText, 11, Enum.Font.GothamBold)

    -- Args preview
    mkLabel(row, argsStr,
        UDim2.new(1,-nameX-130,0,14),
        UDim2.new(0,nameX+122,0,4),
        C.dim, 10, Enum.Font.Code)

    -- Timestamp + count
    mkLabel(row, timestamp.." x"..remoteCount[remotePath],
        UDim2.new(0,70,0,14),
        UDim2.new(1,-72,0,4),
        C.dimDark, 9)

    -- Click to select
    local rowBtn = Instance.new("TextButton")
    rowBtn.Size = UDim2.new(1,0,1,0)
    rowBtn.BackgroundTransparency = 1
    rowBtn.Text = ""
    rowBtn.Parent = row

    rowBtn.MouseButton1Click:Connect(function()
        selectedLog = entry
        -- Update detail
        local detail = string.format("[%s] %s | %s\n%s",
            direction, remoteName, timestamp, argsStr)
        detailLabel.Text = detail

        -- Highlight selected
        for _, c in pairs(rspyScroll:GetChildren()) do
            if c:IsA("Frame") then
                c.BackgroundColor3 = C.panel
            end
        end
        row.BackgroundColor3 = C.goldBr
    end)

    -- Update count label
    rspyCountLabel.Text = #remoteLogs .. " events"

    -- Auto scroll
    if rspyAutoScroll then
        rspyScroll.CanvasPosition = Vector2.new(0, 0)
    end
end

