-- Override print/warn
local _print = print
local _warn = warn

print = function(...)
    local p = {}
    for _,v in ipairs({...}) do table.insert(p, tostring(v)) end
    local msg = table.concat(p,"  ")
    _print(msg)
    addConLog(msg, C.white, "[print]")
end

warn = function(...)
    local p = {}
    for _,v in ipairs({...}) do table.insert(p, tostring(v)) end
    addConLog(table.concat(p,"  "), C.orange, "[warn]")
end

-- ================================================
-- HOOK ALL REMOTES
-- ================================================
local function startHook()
    if not hookmetamethod then
        addConLog("hookmetamethod tidak tersedia!", C.red, "[err]")
        return
    end

    hookOrig = hookmetamethod(game, "__namecall", function(self, ...)
        local method = getnamecallmethod()
        if method == "FireServer" or method == "InvokeServer" then
            local ok, path = pcall(function() return self:GetFullName() end)
            if ok then
                addRspyLog("C>S", self.Name, path, {...})
            end
        end
        return hookOrig(self, ...)
    end)

    local function connectRE(v)
        if v:IsA("RemoteEvent") then
            v.OnClientEvent:Connect(function(...)
                addRspyLog("S>C", v.Name, v:GetFullName(), {...})
            end)
        end
    end

    for _,v in pairs(game:GetDescendants()) do pcall(connectRE, v) end
    game.DescendantAdded:Connect(function(v)
        task.wait()
        pcall(connectRE, v)
    end)

    addConLog("Hook aktif! Semua remote dimonitor.", C.green, "[sys]")
end

startHook()

