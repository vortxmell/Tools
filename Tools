    local function buildChain(path)
        local parts = {}
        for part in path:gmatch("[^%.]+") do
            table.insert(parts, part)
        end
        if #parts == 0 then return nil end
        local chain = 'game:GetService("' .. parts[1] .. '")'
        for i = 2, #parts do
            chain = chain .. ':WaitForChild("' .. parts[i] .. '")'
        end
        return chain
    end

    -- Build args table lines
    local function buildArgsLines(args)
        if not args or #args == 0 then return nil end
        local out = {}
        for _, v in ipairs(args) do
            local t = type(v)
            if t == "string" then
                table.insert(out, '\t"' .. v:gsub('"', '\\"') .. '"')
            elseif t == "number" or t == "boolean" then
                table.insert(out, "\t" .. tostring(v))
            elseif t == "buffer" then
                table.insert(out, "\t-- <buffer> semak Hex panel")
            else
                table.insert(out, "\t-- "..tostring(v))
            end
        end
        return out
    end

    local chain = buildChain(selectedLog.path)
    local argLines = buildArgsLines(selectedLog.args)

    if chain then
        if selectedLog.dir == "C>S" then
            if argLines and #argLines > 0 then
                table.insert(lines, "local args = {")
                for _, al in ipairs(argLines) do
                    table.insert(lines, al..",")
                end
                table.insert(lines, "}")
                table.insert(lines, chain..":FireServer(unpack(args))")
            else
                table.insert(lines, chain..":FireServer()")
            end
        else
            table.insert(lines, "-- S>C remote, server yang fire")
            table.insert(lines, chain..":OnClientEvent:Connect(function(...)")
            table.insert(lines, "\tprint(...)")
            table.insert(lines, "end)")
        end
    end

    if selectedLog.isBuf then
        table.insert(lines, "")
        table.insert(lines, getHexFull(selectedLog.args))
    end

    copyClip(table.concat(lines, "\n"))
    exportSelBtn.Text = "✓ Copied!"
