local function toggleFullsize()
    editorFullsize = not editorFullsize

    if editorFullsize then
        fullsizeBtn.Text = "⊡ Exit"
        fullsizeBtn.BackgroundColor3 = C.goldBr
        fullsizeBtn.TextColor3 = C.bg
        fullCodeBox.Text = sharedCode
        normalPanel.Visible = false
        fullPanel.Visible = true
        task.defer(function()
            fullCodeBox:CaptureFocus()
        end)
    else
        fullsizeBtn.Text = "⛶ Full"
        fullsizeBtn.BackgroundColor3 = C.dimDark
        fullsizeBtn.TextColor3 = C.goldText
        sharedCode = fullCodeBox.Text
        syncToBar()
        fullPanel.Visible = false
        normalPanel.Visible = true
    end
end

