-- ================================================
-- EDITOR SIZE UPDATE
-- ================================================
local function updateEditorSize()
    local text = fullCodeBox.Text
    local lineCount = 1
    for _ in text:gmatch("\n") do lineCount += 1 end
    lineCount += 3
    local totalH = math.max(MIN_EDITOR_H, lineCount * LINE_HEIGHT)
    fullCodeBox.Size = UDim2.new(1,-8, 0, totalH)
    editorScroll.CanvasSize = UDim2.new(0,0, 0, totalH+16)
    local actual = 1
    for _ in text:gmatch("\n") do actual += 1 end
    lineCountLabel.Text = actual.." lines"
end

-- ================================================
-- MANUAL SCROLL
-- ================================================
local SCROLL_SPEED = 3.5
local lastTouchY   = nil
local isTouching   = false

editorScroll.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.Touch then
        lastTouchY = input.Position.Y
        isTouching = true
    end
end)

editorScroll.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.Touch
        and isTouching and lastTouchY then
        local delta = lastTouchY - input.Position.Y
        local maxY  = math.max(0,
            editorScroll.CanvasSize.Y.Offset - editorScroll.AbsoluteSize.Y)
        editorScroll.CanvasPosition = Vector2.new(0,
            math.clamp(
                editorScroll.CanvasPosition.Y + delta * SCROLL_SPEED,
                0, maxY))
        lastTouchY = input.Position.Y
    end
    if input.UserInputType == Enum.UserInputType.MouseWheel then
        local maxY = math.max(0,
            editorScroll.CanvasSize.Y.Offset - editorScroll.AbsoluteSize.Y)
        editorScroll.CanvasPosition = Vector2.new(0,
            math.clamp(
                editorScroll.CanvasPosition.Y - input.Position.Z*60*SCROLL_SPEED,
                0, maxY))
    end
end)

editorScroll.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.Touch then
        isTouching = false
        lastTouchY = nil
    end
end)

-- Auto scroll ikut cursor
fullCodeBox:GetPropertyChangedSignal("CursorPosition"):Connect(function()
    task.defer(function()
        if not editorFullsize then return end
        local pos = fullCodeBox.CursorPosition
        if pos == -1 then return end
        local lineNum = 0
        for _ in fullCodeBox.Text:sub(1,pos-1):gmatch("\n") do
            lineNum += 1
        end
        local cursorY   = lineNum * LINE_HEIGHT
        local scrollTop = editorScroll.CanvasPosition.Y
        local scrollBot = scrollTop + editorScroll.AbsoluteSize.Y
        local margin    = 32
        if cursorY < scrollTop + margin then
            editorScroll.CanvasPosition = Vector2.new(0,
                math.max(0, cursorY - margin))
        elseif cursorY > scrollBot - margin then
            editorScroll.CanvasPosition = Vector2.new(0,
                cursorY - editorScroll.AbsoluteSize.Y + margin)
        end
    end)
end)

