local function copyClip(text)
    if setclipboard then
        setclipboard(text)
    elseif toclipboard then
        toclipboard(text)
    elseif Clipboard and Clipboard.set then
        Clipboard.set(text)
    else
        _G.lastCopy = text
        print("[Copy] Saved to _G.lastCopy")
    end
end

