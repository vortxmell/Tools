-- Track window position untuk keyboard offset
local keyboardVisible = false
local baseWinPos = nil  -- simpan posisi sebelum keyboard naik

local function getWinAbsPos()
    return Vector2.new(
        mainWin.AbsolutePosition.X,
        mainWin.AbsolutePosition.Y
    )
end

local function getWinAbsSize()
    return Vector2.new(
        mainWin.AbsoluteSize.X,
        mainWin.AbsoluteSize.Y
    )
end

UIS.TextBoxFocused:Connect(function()
    task.wait(0.15) -- tunggu keyboard animate
    if keyboardVisible then return end
    keyboardVisible = true

    -- Simpan posisi semasa
    local absPos = getWinAbsPos()
    local absSize = getWinAbsSize()
    local screenSize = gui.AbsoluteSize

    -- Anggaran keyboard height (~40% screen pada mobile)
    local kbHeight = screenSize.Y * 0.42
    local winBottom = absPos.Y + absSize.Y
    local visibleAreaBottom = screenSize.Y - kbHeight

    baseWinPos = mainWin.Position

    -- Kalau window terlindung keyboard, gerak ke atas
    if winBottom > visibleAreaBottom then
        local overlap = winBottom - visibleAreaBottom + 10
        local newY = absPos.Y - overlap

        -- Pastikan tak keluar screen atas
        newY = math.max(10, newY)

        mainWin.Position = UDim2.new(0, absPos.X, 0, newY)
    end
end)

UIS.TextBoxFocusReleased:Connect(function()
    task.wait(0.1)
    keyboardVisible = false

    -- Restore posisi asal
    if baseWinPos then
        mainWin.Position = baseWinPos
        baseWinPos = nil
    end
end)

