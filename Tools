-- ================================================
-- MESSAGEPACK DECODER
-- Pure Lua implementation
-- Supports: nil, bool, int, float, string,
--           binary, array, map (nested)
-- ================================================
local MsgPack = {}

local function mpDecode(buf, pos)
    local b = buffer.readu8(buf, pos)
    pos += 1

    -- positive fixint 0x00-0x7f
    if b <= 0x7f then return b, pos end

    -- fixmap 0x80-0x8f
    if b >= 0x80 and b <= 0x8f then
        local n = b - 0x80
        local map = {}
        for _ = 1, n do
            local k, v
            k, pos = mpDecode(buf, pos)
            v, pos = mpDecode(buf, pos)
            map[k] = v
        end
        return map, pos
    end

    -- fixarray 0x90-0x9f
    if b >= 0x90 and b <= 0x9f then
        local n = b - 0x90
        local arr = {}
        for i = 1, n do arr[i], pos = mpDecode(buf, pos) end
        return arr, pos
    end

    -- fixstr 0xa0-0xbf
    if b >= 0xa0 and b <= 0xbf then
        local n = b - 0xa0
        if n == 0 then return "", pos end
        local chars = {}
        for i = 0, n-1 do
            table.insert(chars, string.char(buffer.readu8(buf, pos+i)))
        end
        return table.concat(chars), pos + n
    end

    -- nil
    if b == 0xc0 then return nil, pos end

    -- false
    if b == 0xc2 then return false, pos end

    -- true
    if b == 0xc3 then return true, pos end

    -- bin8
    if b == 0xc4 then
        local n = buffer.readu8(buf, pos); pos += 1
        local hex = {}
        for i = 0, n-1 do table.insert(hex, string.format("%02X", buffer.readu8(buf, pos+i))) end
        return "<bin:"..n.."b>["..table.concat(hex," ").."]", pos + n
    end

    -- bin16
    if b == 0xc5 then
        local n = buffer.readu16(buf, pos); pos += 2
        local hex = {}
        for i = 0, math.min(n-1,15) do table.insert(hex, string.format("%02X", buffer.readu8(buf, pos+i))) end
        return "<bin:"..n.."b>["..table.concat(hex," ")..(n>16 and "..." or "").."]", pos + n
    end

    -- float32
    if b == 0xca then
        local v = buffer.readf32(buf, pos); pos += 4
        return v, pos
    end

    -- float64
    if b == 0xcb then
        local v = buffer.readf64(buf, pos); pos += 8
        return v, pos
    end

    -- uint8
    if b == 0xcc then local v = buffer.readu8(buf, pos);  pos+=1; return v, pos end
    -- uint16
    if b == 0xcd then local v = buffer.readu16(buf, pos); pos+=2; return v, pos end
    -- uint32
    if b == 0xce then local v = buffer.readu32(buf, pos); pos+=4; return v, pos end

    -- int8
    if b == 0xd0 then local v = buffer.readi8(buf, pos);  pos+=1; return v, pos end
    -- int16
    if b == 0xd1 then local v = buffer.readi16(buf, pos); pos+=2; return v, pos end
    -- int32
    if b == 0xd2 then local v = buffer.readi32(buf, pos); pos+=4; return v, pos end

    -- str8
    if b == 0xd9 then
        local n = buffer.readu8(buf, pos); pos += 1
        local chars = {}
        for i = 0, n-1 do table.insert(chars, string.char(buffer.readu8(buf, pos+i))) end
        return table.concat(chars), pos + n
    end

    -- str16
    if b == 0xda then
        local n = buffer.readu16(buf, pos); pos += 2
        local chars = {}
        for i = 0, n-1 do table.insert(chars, string.char(buffer.readu8(buf, pos+i))) end
        return table.concat(chars), pos + n
    end

    -- str32
    if b == 0xdb then
        local n = buffer.readu32(buf, pos); pos += 4
        local chars = {}
        for i = 0, n-1 do table.insert(chars, string.char(buffer.readu8(buf, pos+i))) end
        return table.concat(chars), pos + n
    end

    -- array16
    if b == 0xdc then
        local n = buffer.readu16(buf, pos); pos += 2
        local arr = {}
        for i = 1, n do arr[i], pos = mpDecode(buf, pos) end
        return arr, pos
    end

    -- array32
    if b == 0xdd then
        local n = buffer.readu32(buf, pos); pos += 4
        local arr = {}
        for i = 1, n do arr[i], pos = mpDecode(buf, pos) end
        return arr, pos
    end

    -- map16
    if b == 0xde then
        local n = buffer.readu16(buf, pos); pos += 2
        local map = {}
        for _ = 1, n do
            local k, v
            k, pos = mpDecode(buf, pos)
            v, pos = mpDecode(buf, pos)
            map[k] = v
        end
        return map, pos
    end

    -- map32
    if b == 0xdf then
        local n = buffer.readu32(buf, pos); pos += 4
        local map = {}
        for _ = 1, n do
            local k, v
            k, pos = mpDecode(buf, pos)
            v, pos = mpDecode(buf, pos)
            map[k] = v
        end
        return map, pos
    end

    -- negative fixint 0xe0-0xff
    if b >= 0xe0 then return b - 256, pos end

    return "??0x"..string.format("%02X",b), pos
end

-- Pretty print decoded value
local function mpPretty(val, indent)
    indent = indent or 0
    local pad = string.rep("  ", indent)
    local t = type(val)
    if val == nil then return "null"
    elseif t == "boolean" then return tostring(val)
    elseif t == "number" then
        if val == math.floor(val) then return tostring(math.floor(val))
        else return string.format("%.6g", val) end
    elseif t == "string" then return '"'..val..'"'
    elseif t == "table" then
        -- Check if array
        local isArr = true
        local maxN = 0
        for k,_ in pairs(val) do
            if type(k) ~= "number" or k ~= math.floor(k) or k < 1 then isArr = false; break end
            if k > maxN then maxN = k end
        end
        if isArr and maxN == #val and maxN > 0 then
            local lines = {"["}
            for i, v in ipairs(val) do
                lines[#lines+1] = pad.."  "..mpPretty(v, indent+1)
                    ..(i<#val and "," or "")
            end
            lines[#lines+1] = pad.."]"
            return table.concat(lines, "\n")
        else
            local lines = {"{"}
            local i = 0
            for k, v in pairs(val) do
                i += 1
                lines[#lines+1] = pad.."  "..tostring(k)..": "..mpPretty(v, indent+1)
            end
            lines[#lines+1] = pad.."}"
            return table.concat(lines, "\n")
        end
    else return tostring(val) end
end

function MsgPack.decode(buf)
    local ok, result, _ = pcall(function()
        return mpDecode(buf, 0)
    end)
    if not ok then return nil, "Decode error: "..tostring(result) end
    return result, nil
end

function MsgPack.decodeAll(buf)
    local results = {}
    local pos = 0
    local len = buffer.len(buf)
    while pos < len do
        local ok, val, newpos = pcall(function()
            return mpDecode(buf, pos)
        end)
        if not ok then
            table.insert(results, "⚠ Error at byte "..pos..": "..tostring(val))
            break
        end
        table.insert(results, val)
        pos = newpos
    end
    return results
end

-- ================================================
-- rSPY HELPERS
-- ================================================
local function describeValue(v)
    local t = type(v)
    if t=="buffer" then
        local len=buffer.len(v); local hex={}
        for i=0,math.min(len-1,6) do table.insert(hex,string.format("%02X",buffer.readu8(v,i))) end
        return string.format("<buf:%db>[%s%s]",len,table.concat(hex," "),len>7 and "..." or "")
    elseif t=="Instance" then return "["..v.ClassName.."]"..v.Name
    elseif t=="Vector3"  then return string.format("V3(%.1f,%.1f,%.1f)",v.X,v.Y,v.Z)
    elseif t=="table" then
        local p,c={},0
        for k,val in pairs(v) do c+=1; if c<=3 then table.insert(p,tostring(k).."="..tostring(val)) end end
        return "{"..table.concat(p,",")..(c>3 and "..." or "").."}"
    else return tostring(v) end
end

local function describeArgs(args)
    if #args==0 then return "(no args)" end
    local p={}; for _,v in ipairs(args) do table.insert(p,describeValue(v)) end
    return table.concat(p,", ")
end

local function hasBuffer(args)
    for _,v in ipairs(args) do if type(v)=="buffer" then return true end end
    return false
end

local function getHexFull(args)
    local r={}
    for i,v in ipairs(args) do
        if type(v)=="buffer" then
            local len=buffer.len(v); local hex,asc={},{}
            for j=0,len-1 do
                local b=buffer.readu8(v,j)
                table.insert(hex,string.format("%02X",b))
                table.insert(asc,(b>=32 and b<=126) and string.char(b) or ".")
            end
            table.insert(r,string.format("[Arg%d %db]\nHEX: %s\nASC: %s",
                i,len,table.concat(hex," "),table.concat(asc,"")))
        else table.insert(r,"[Arg"..i.."] "..tostring(v)) end
    end
    return table.concat(r,"\n")
end

-- Build WaitForChild chain from full path (shared helper)
local function buildChain(path)
    local parts={}
    for p in path:gmatch("[^%.]+") do table.insert(parts,p) end
    if #parts==0 then return nil end
    local chain='game:GetService("'..parts[1]..'")'
    for i=2,#parts do chain=chain..':WaitForChild("'..parts[i]..'")' end
    return chain
end

-- Build args lines for script generation (shared helper)
local function buildArgsLines(args)
    if not args or #args==0 then return nil end
    local out={}
    for _,v in ipairs(args) do
        local t=type(v)
        if t=="string" then table.insert(out,'\t"'..v:gsub('"','\\"')..'"')
        elseif t=="number" or t=="boolean" then table.insert(out,"\t"..tostring(v))
        elseif t=="buffer" then table.insert(out,"\t-- <buffer> semak Hex")
        else table.insert(out,"\t-- "..tostring(v)) end
    end
    return out
end

-- Generate exploit script string (shared helper)
local function generateScript(log)
    if not log then return nil end
    local chain    = buildChain(log.path)
    local argLines = buildArgsLines(log.args)
    local lines    = {}
    if chain then
        if log.dir=="C>S" then
            -- Detect remote type dari remoteClass atau method
            local fireMethod = "FireServer"
            if log.remoteClass == "RemoteFunction" then
                fireMethod = "InvokeServer"
            elseif log.remoteClass == "UnreliableRemoteEvent" then
                fireMethod = "FireUnreliableServer"
            end

            if argLines and #argLines>0 then
                table.insert(lines,"local args = {")
                for _,al in ipairs(argLines) do table.insert(lines,al..",") end
                table.insert(lines,"}")
                table.insert(lines,chain..":"..fireMethod.."(unpack(args))")
            else
                table.insert(lines,chain..":"..fireMethod.."()")
            end

            -- Kalau InvokeServer, tambah comment pasal return value
            if fireMethod == "InvokeServer" then
                table.insert(lines,"-- InvokeServer returns value dari server")
                if log.retStr then
                    table.insert(lines,"-- Return: "..log.retStr)
                end
            end
        else
            -- S>C
            local eventMethod = "OnClientEvent"
            if log.remoteClass == "RemoteFunction" then
                eventMethod = "OnClientInvoke"
            end
            table.insert(lines,"-- S>C remote, server yang fire")
            if log.remoteClass == "RemoteFunction" then
                table.insert(lines,chain.."."..eventMethod.." = function(...)")
                table.insert(lines,"\tprint(...)")
                table.insert(lines,"\treturn nil -- return value ke server")
                table.insert(lines,"end")
            else
                table.insert(lines,chain..":"..eventMethod..":Connect(function(...)")
                table.insert(lines,"\tprint(...)"); table.insert(lines,"end)")
            end
        end
    end
    return table.concat(lines,"\n")
end

-- ================================================
-- rSPY LOG BUILDER
-- Hook sentiasa capture. rspyVisible = display control je.
-- ================================================
local function addRspyLog(dir, name, path, args, returnVal, remoteClass)
    if not rspyVisible then return end
    if dirFilter=="cs" and dir~="C>S" then return end
    if dirFilter=="sc" and dir~="S>C" then return end
    local f = rspySearch.Text:lower()
    if f~="" and not name:lower():find(f,1,true) then return end

    -- ── Filter: Ignore list ──
    if filterIgnore[name:lower()] then return end

    -- ── Filter: Rate limit ──
    if filterRateMax > 0 then
        local now = os.clock()
        local track = filterRateTrack[path]
        if not track then
            filterRateTrack[path] = {count=1, windowStart=now}
        else
            if now - track.windowStart >= 1 then
                -- Reset window
                track.count = 1
                track.windowStart = now
            else
                track.count += 1
                if track.count > filterRateMax then return end
            end
        end
    end

    -- ── Filter: Unique mode ──
    if filterUnique then
        if filterSeen[path] then return end
        filterSeen[path] = true
    end

    remoteCount[path] = (remoteCount[path] or 0)+1
    local now        = os.clock()
    local intervalMs = remoteLastFire[path] and math.floor((now-remoteLastFire[path])*1000) or nil
    remoteLastFire[path] = now

    local isBuf   = hasBuffer(args)
    local argsStr = describeArgs(args)
    local ts      = os.date("%M:%S")

    -- Describe return value
    local retStr = nil
    if returnVal ~= nil then
        retStr = describeValue(returnVal)
    end

    local entry = {
        dir=dir, name=name, path=path,
        args=args, argsStr=argsStr,
        isBuf=isBuf, time=ts, intervalMs=intervalMs,
        returnVal=returnVal, retStr=retStr,
        remoteClass=remoteClass or "RemoteEvent"
    }
    table.insert(remoteLogs,1,entry)
    if #remoteLogs>maxLogs then table.remove(remoteLogs) end

    local dirColor = dir=="C>S" and C.orange or dir=="S>C" and C.blue or C.purple

    -- Kalau ada return value, row height lebih tinggi sikit
    local rowH = retStr and 48 or 34
    local row = mkFrame(rspyScroll,UDim2.new(1,-4,0,rowH),nil,C.panel,3)
    row.LayoutOrder = -os.clock()*1000

    -- Dir tag
    local dtag = mkFrame(row,UDim2.new(0,28,0,14),UDim2.new(0,3,0,2),dirColor,3)
    mkLabel(dtag,dir,UDim2.new(1,0,1,0),nil,C.bg,8,Enum.Font.GothamBold,Enum.TextXAlignment.Center)

    -- Invoke tag (kalau InvokeServer)
    local nameX = 34
    if isBuf then
        local btag = mkFrame(row,UDim2.new(0,20,0,12),UDim2.new(0,34,0,3),C.purple,3)
        mkLabel(btag,"buf",UDim2.new(1,0,1,0),nil,C.white,7,Enum.Font.GothamBold,Enum.TextXAlignment.Center)
        nameX = 57
    end
    if retStr then
        local itag = mkFrame(row,UDim2.new(0,26,0,12),UDim2.new(0,nameX,0,3),Color3.fromRGB(0,180,120),3)
        mkLabel(itag,"inv",UDim2.new(1,0,1,0),nil,C.white,7,Enum.Font.GothamBold,Enum.TextXAlignment.Center)
        nameX = nameX + 29
    end

    -- Interval badge
    local iStr   = intervalMs and (intervalMs>=1000 and string.format("+%.1fs",intervalMs/1000) or "+"..intervalMs.."ms") or "new"
    local iColor = not intervalMs and C.dim or intervalMs<50 and C.red or intervalMs<100 and C.orange or C.green
    local ibadge = mkFrame(row,UDim2.new(0,54,0,14),UDim2.new(1,-57,0,2),C.panelDark,3)
    mkLabel(ibadge,iStr,UDim2.new(1,0,1,0),nil,iColor,9,Enum.Font.GothamBold,Enum.TextXAlignment.Center)

    mkLabel(row,"x"..remoteCount[path],UDim2.new(0,24,0,14),UDim2.new(1,-83,0,2),C.white,9,Enum.Font.Gotham,Enum.TextXAlignment.Right)
    mkLabel(row,ts,UDim2.new(0,32,0,12),UDim2.new(1,-83,0,18),C.white,8,Enum.Font.Gotham,Enum.TextXAlignment.Right)
    mkLabel(row,name,UDim2.new(1,-nameX-90,0,14),UDim2.new(0,nameX,0,2),C.goldText,11,Enum.Font.GothamBold)
    mkLabel(row,argsStr,UDim2.new(1,-8,0,13),UDim2.new(0,4,0,18),C.white,9,Enum.Font.Code)

    -- Return value line (kalau ada)
    if retStr then
        local retRow = mkFrame(row,UDim2.new(1,-8,0,13),UDim2.new(0,4,0,32),Color3.fromRGB(0,30,20),3)
        mkLabel(retRow,"↩ "..retStr,UDim2.new(1,-4,1,0),UDim2.new(0,2,0,0),Color3.fromRGB(0,220,140),9,Enum.Font.Code)
    end

    local rb = Instance.new("TextButton")
    rb.Size = UDim2.new(1,0,1,0); rb.BackgroundTransparency = 1; rb.Text = ""; rb.Parent = row
    rb.MouseButton1Click:Connect(function()
        selectedLog = entry

        local cStr = intervalMs and (intervalMs>=1000 and string.format("%.2fs",intervalMs/1000) or intervalMs.."ms") or "first"
        local detailText = string.format("[%s] %s  %s\n%s\n\nArgs: %s",dir,name,cStr,path,argsStr)
        if retStr then
            detailText = detailText.."\n\n↩ Return:\n"..retStr
        end
        detailLabel.Text = detailText

        -- Populate args editor
        local edLines={}
        for _,v in ipairs(entry.args or {}) do
            local t=type(v)
            if t=="string" then table.insert(edLines,'"'..v:gsub('"','\\"')..'"')
            elseif t=="number" or t=="boolean" then table.insert(edLines,tostring(v))
            elseif t=="buffer" then table.insert(edLines,"-- <buffer>")
            else table.insert(edLines,"-- "..tostring(v)) end
        end
        argsEditor.Text = table.concat(edLines,"\n")
        if intervalMs and intervalMs>0 then intervalInput.Text = tostring(intervalMs) end

        for _,c in pairs(rspyScroll:GetChildren()) do
            if c:IsA("Frame") then c.BackgroundColor3=C.panel end
        end
        row.BackgroundColor3 = C.goldBr
    end)

    rspyCount.Text = #remoteLogs.." events"
    if rspyAutoScroll then rspyScroll.CanvasPosition = Vector2.new(0,0) end
end

