-- ================================================
-- HOOK ALL REMOTES
-- hookmetamethod capture SEMUA sumber.
-- newcclosure wrap — hide dari getconnections scan.
-- ================================================
local hookOrig = nil

local function startHook()
    if not hookmetamethod then
        addConLog("hookmetamethod tidak tersedia!", C.red,"[err]"); return
    end

    -- newcclosure buat callback nampak macam native C function
    -- anti-cheat yang scan getconnections nampak native, bukan Lua script
    local hookCb = newcclosure and newcclosure(function(self,...)
        local method = getnamecallmethod()
        local args   = {...}
        local result = hookOrig(self,...)

        if method=="FireServer" then
            local name = self.Name
            local ok,path = pcall(function() return self:GetFullName() end)
            if ok then
                local cls = pcall(function() return self.ClassName end) and self.ClassName or "RemoteEvent"
                task.defer(function() pcall(addRspyLog,"C>S",name,path,args,nil,cls) end)
            end
        elseif method=="FireUnreliableServer" then
            local name = self.Name
            local ok,path = pcall(function() return self:GetFullName() end)
            if ok then
                task.defer(function() pcall(addRspyLog,"C>S",name,path,args,nil,"UnreliableRemoteEvent") end)
            end
        elseif method=="InvokeServer" then
            local name = self.Name
            local ok,path = pcall(function() return self:GetFullName() end)
            if ok then
                local retVal = result
                task.defer(function() pcall(addRspyLog,"C>S",name,path,args,retVal,"RemoteFunction") end)
            end
        end

        return result
    end) or function(self,...)  -- fallback kalau newcclosure nil
        local method = getnamecallmethod()
        local args   = {...}
        local result = hookOrig(self,...)

        if method=="FireServer" then
            local name = self.Name
            local ok,path = pcall(function() return self:GetFullName() end)
            if ok then
                local cls = pcall(function() return self.ClassName end) and self.ClassName or "RemoteEvent"
                task.defer(function() pcall(addRspyLog,"C>S",name,path,args,nil,cls) end)
            end
        elseif method=="FireUnreliableServer" then
            local name = self.Name
            local ok,path = pcall(function() return self:GetFullName() end)
            if ok then
                task.defer(function() pcall(addRspyLog,"C>S",name,path,args,nil,"UnreliableRemoteEvent") end)
            end
        elseif method=="InvokeServer" then
            local name = self.Name
            local ok,path = pcall(function() return self:GetFullName() end)
            if ok then
                local retVal = result
                task.defer(function() pcall(addRspyLog,"C>S",name,path,args,retVal,"RemoteFunction") end)
            end
        end

        return result
    end

    hookOrig = hookmetamethod(game,"__namecall", hookCb)

    -- S>C — guna cloneref pada remote instance
    local function connectRE(v)
        if v:IsA("RemoteEvent") or v:IsA("UnreliableRemoteEvent") then
            local cv  = _cloneref(v)
            local cls = cv.ClassName
            cv.OnClientEvent:Connect(newcclosure and newcclosure(function(...)
                local args={...}; local path=""
                pcall(function() path=cv:GetFullName() end)
                task.defer(function() pcall(addRspyLog,"S>C",cv.Name,path,args,nil,cls) end)
            end) or function(...)
                local args={...}; local path=""
                pcall(function() path=cv:GetFullName() end)
                task.defer(function() pcall(addRspyLog,"S>C",cv.Name,path,args,nil,cls) end)
            end)
        end
    end

    for _,v in pairs(game:GetDescendants()) do pcall(connectRE,v) end
    game.DescendantAdded:Connect(function(v) task.wait(); pcall(connectRE,v) end)

    addConLog("Hook aktif! Capture semua sumber.", C.green,"[sys]")
    addConLog("Play/Stop = toggle display | hook sentiasa on.", C.dim,"[sys]")
end

startHook()

