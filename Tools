local function mkFrame(parent, size, pos, color, radius)
    local f = Instance.new("Frame")
    f.Size             = size  or UDim2.new(0,100,0,100)
    f.Position         = pos   or UDim2.new(0,0,0,0)
    f.BackgroundColor3 = color or C.panel
    f.BorderSizePixel  = 0
    f.ClipsDescendants = false
    f.Parent           = parent
    if radius then Instance.new("UICorner",f).CornerRadius = UDim.new(0,radius) end
    return f
end

local function mkLabel(parent, text, size, pos, tc, fs, font, xa)
    local l = Instance.new("TextLabel")
    l.Size           = size or UDim2.new(1,0,1,0)
    l.Position       = pos  or UDim2.new(0,0,0,0)
    l.BackgroundTransparency = 1
    l.Text           = text or ""
    l.TextColor3     = tc   or C.goldText
    l.TextSize       = fs   or 12
    l.Font           = font or Enum.Font.Gotham
    l.TextXAlignment = xa   or Enum.TextXAlignment.Left
    l.TextTruncate   = Enum.TextTruncate.AtEnd
    l.Parent         = parent
    return l
end

local function mkBtn(parent, text, size, pos, bg, tc, fs)
    local b = Instance.new("TextButton")
    b.Size             = size or UDim2.new(0,80,0,28)
    b.Position         = pos  or UDim2.new(0,0,0,0)
    b.BackgroundColor3 = bg   or C.gold
    b.BorderSizePixel  = 0
    b.Text             = text or ""
    b.TextColor3       = tc   or C.bg
    b.TextSize         = fs   or 12
    b.Font             = Enum.Font.GothamBold
    b.AutoButtonColor  = true
    b.Parent           = parent
    Instance.new("UICorner",b).CornerRadius = UDim.new(0,5)
    return b
end

local function mkInput(parent, ph, size, pos)
    local b = Instance.new("TextBox")
    b.Size             = size or UDim2.new(1,0,0,28)
    b.Position         = pos  or UDim2.new(0,0,0,0)
    b.BackgroundColor3 = C.panelDark
    b.BorderSizePixel  = 0
    b.Text             = ""
    b.PlaceholderText  = ph or ""
    b.TextColor3       = C.goldText
    b.PlaceholderColor3= C.dim
    b.TextSize         = 11
    b.Font             = Enum.Font.Gotham
    b.TextXAlignment   = Enum.TextXAlignment.Left
    b.ClearTextOnFocus = false
    b.Parent           = parent
    Instance.new("UICorner",b).CornerRadius = UDim.new(0,5)
    Instance.new("UIPadding",b).PaddingLeft = UDim.new(0,6)
    return b
end

local function mkScroll(parent, size, pos)
    local s = Instance.new("ScrollingFrame")
    s.Size                 = size or UDim2.new(1,0,1,0)
    s.Position             = pos  or UDim2.new(0,0,0,0)
    s.BackgroundColor3     = C.panelDark
    s.BorderSizePixel      = 0
    s.ScrollBarThickness   = 4
    s.ScrollBarImageColor3 = C.gold
    s.CanvasSize           = UDim2.new(0,0,0,0)
    s.AutomaticCanvasSize  = Enum.AutomaticSize.Y
    s.Parent               = parent
    Instance.new("UICorner",s).CornerRadius = UDim.new(0,5)
    local l = Instance.new("UIListLayout",s)
    l.SortOrder = Enum.SortOrder.LayoutOrder
    l.Padding   = UDim.new(0,1)
    return s
end

local function mkStroke(parent, color, thick)
    local s = Instance.new("UIStroke",parent)
    s.Color     = color or C.gold
    s.Thickness = thick or 1
    return s
end

