local function setTab(name)
    activeTab = name
    for tname, btn in pairs(tabs) do
        if tname == name then
            btn.BackgroundColor3 = C.tabActive
            btn.TextColor3 = C.goldText
        else
            btn.BackgroundColor3 = C.tabInactive
            btn.TextColor3 = C.dim
        end
    end
    for tname, content in pairs(tabContents) do
        content.Visible = (tname == name)
    end
end

local function addTab(name, label, icon)
    local tabCount = 0
    for _ in pairs(tabs) do tabCount += 1 end

    local btn = mkBtn(tabBar, icon.." "..label,
        UDim2.new(0,100,1,-4),
        UDim2.new(0, 4 + tabCount*104, 0, 2),
