    table.insert(lines, "Path: "..selectedLog.path)
    table.insert(lines, "Dir:  "..selectedLog.dir)
    table.insert(lines, "Time: "..selectedLog.time)
    table.insert(lines, "Args: "..selectedLog.argsStr)
    table.insert(lines, "")
