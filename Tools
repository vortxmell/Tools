-- Execute lua
runBtn.MouseButton1Click:Connect(function()
    local code = codeInput.Text
    if code == "" then return end
    addConLog("> "..code, C.goldText, "[exec]")
    codeInput.Text = ""
    local fn, err = loadstring(code)
    if fn then
        local ok, res = pcall(fn)
        if ok then
            if res ~= nil then
                addConLog(tostring(res), C.green, "[ok]")
            end
        else
            addConLog(tostring(res), C.red, "[err]")
        end
    else
        addConLog(tostring(err), C.red, "[err]")
    end
end)

