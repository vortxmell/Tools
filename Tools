-- ================================================
-- HOOK ALL REMOTES
-- hookmetamethod capture SEMUA sumber:
-- game sendiri, console kita, console lain, IY, script lain.
-- rspyVisible = display control je, hook sentiasa aktif.
-- ================================================
local hookOrig = nil

local function startHook()
    if not hookmetamethod then
        addConLog("hookmetamethod tidak tersedia!", C.red,"[err]"); return
    end

    hookOrig = hookmetamethod(game,"__namecall",function(self,...)
        local method = getnamecallmethod()
        local args   = {...}

        -- Original call DULU — zero interference
        local result = hookOrig(self,...)

        -- Log semua remote tanpa kira sumber (termasuk IY, console lain, dll)
        if method=="FireServer"
        or method=="InvokeServer"
        or method=="FireUnreliableServer" then
            local name = self.Name
            local ok,path = pcall(function() return self:GetFullName() end)
            if ok then
                task.defer(function() pcall(addRspyLog,"C>S",name,path,args) end)
            end
        end

        return result
    end)

    -- S>C
    local function connectRE(v)
        if v:IsA("RemoteEvent") then
            v.OnClientEvent:Connect(function(...)
                local args={...}; local path=""
                pcall(function() path=v:GetFullName() end)
                task.defer(function() pcall(addRspyLog,"S>C",v.Name,path,args) end)
            end)
        end
    end

    for _,v in pairs(game:GetDescendants()) do pcall(connectRE,v) end
    game.DescendantAdded:Connect(function(v) task.wait(); pcall(connectRE,v) end)

    addConLog("Hook aktif! Capture semua sumber.", C.green,"[sys]")
    addConLog("Play/Stop = toggle display | hook sentiasa on.", C.dim,"[sys]")
end

startHook()

