-- ================================================
-- rSPY HELPERS
-- ================================================
local function describeValue(v)
    local t = type(v)
    if t == "buffer" then
        local len = buffer.len(v)
        local hex = {}
        for i=0,math.min(len-1,6) do
            table.insert(hex,string.format("%02X",buffer.readu8(v,i)))
        end
        return string.format("<buf:%db>[%s%s]",
            len,table.concat(hex," "),len>7 and "..." or "")
    elseif t == "Instance" then
        return "["..v.ClassName.."]"..v.Name
    elseif t == "Vector3" then
        return string.format("V3(%.1f,%.1f,%.1f)",v.X,v.Y,v.Z)
    elseif t == "table" then
        local p,c = {},0
        for k,val in pairs(v) do
            c+=1
            if c<=3 then table.insert(p,tostring(k).."="..tostring(val)) end
        end
        return "{"..table.concat(p,",")..(c>3 and "..." or "").."}"
    else
        return tostring(v)
    end
end

local function describeArgs(args)
    if #args==0 then return "(no args)" end
    local p = {}
    for _,v in ipairs(args) do table.insert(p,describeValue(v)) end
    return table.concat(p,", ")
end

local function hasBuffer(args)
    for _,v in ipairs(args) do
        if type(v)=="buffer" then return true end
    end
    return false
end

local function getHexFull(args)
    local r = {}
    for i,v in ipairs(args) do
        if type(v)=="buffer" then
            local len = buffer.len(v)
            local hex,asc = {},{}
            for j=0,len-1 do
                local b = buffer.readu8(v,j)
                table.insert(hex,string.format("%02X",b))
                table.insert(asc,(b>=32 and b<=126) and string.char(b) or ".")
            end
            table.insert(r,string.format("[Arg%d %db]\nHEX: %s\nASC: %s",
                i,len,table.concat(hex," "),table.concat(asc,"")))
        else
            table.insert(r,"[Arg"..i.."] "..tostring(v))
        end
    end
    return table.concat(r,"\n")
end

-- ================================================
-- rSPY LOG BUILDER
-- ================================================
local function addRspyLog(dir, name, path, args)
    if paused then return end
    if blockedRemotes[path] then return end
    local filter = rspySearch.Text:lower()
    if filter~="" and not name:lower():find(filter,1,true) then return end

    remoteCount[path] = (remoteCount[path] or 0)+1
    local isBuf   = hasBuffer(args)
    local argsStr = describeArgs(args)
    local ts      = os.date("%M:%S")

    local entry = {
        dir=dir, name=name, path=path,
        args=args, argsStr=argsStr,
        isBuf=isBuf, time=ts
    }
    table.insert(remoteLogs,1,entry)
    if #remoteLogs>maxLogs then table.remove(remoteLogs) end

    local dirColor = dir=="C>S" and C.orange
        or dir=="S>C" and C.blue or C.purple

    local row = mkFrame(rspyScroll,
        UDim2.new(1,-4,0,28), nil, C.panel, 3)
    row.LayoutOrder = -os.clock()*1000

    local dtag = mkFrame(row,
        UDim2.new(0,30,0,16), UDim2.new(0,3,0,6), dirColor, 3)
    mkLabel(dtag, dir,
        UDim2.new(1,0,1,0), nil,
        C.bg, 9, Enum.Font.GothamBold, Enum.TextXAlignment.Center)

    if isBuf then
        local btag = mkFrame(row,
            UDim2.new(0,22,0,13), UDim2.new(0,36,0,8), C.purple, 3)
        mkLabel(btag,"buf",
            UDim2.new(1,0,1,0), nil,
            C.white, 8, Enum.Font.GothamBold, Enum.TextXAlignment.Center)
    end

    local nx = isBuf and 62 or 36
    mkLabel(row, name,
        UDim2.new(0,110,0,14), UDim2.new(0,nx,0,2),
        C.goldText, 11, Enum.Font.GothamBold)
    mkLabel(row, argsStr,
        UDim2.new(1,-nx-118,0,13),
        UDim2.new(0,nx+112,0,4),
        C.dim, 10, Enum.Font.Code)
    mkLabel(row, ts.." x"..remoteCount[path],
        UDim2.new(0,65,0,12), UDim2.new(1,-67,0,4),
        C.dimDark, 9)

    local rb = Instance.new("TextButton")
    rb.Size = UDim2.new(1,0,1,0)
    rb.BackgroundTransparency = 1
    rb.Text = ""
    rb.Parent = row
    rb.MouseButton1Click:Connect(function()
        selectedLog = entry
        detailLabel.Text = string.format("[%s] %s | %s\n%s",
            dir,name,ts,argsStr)
        for _,c in pairs(rspyScroll:GetChildren()) do
            if c:IsA("Frame") then c.BackgroundColor3=C.panel end
        end
        row.BackgroundColor3 = C.goldBr
    end)

    rspyCount.Text = #remoteLogs.." events"
    if rspyAutoScroll then
        rspyScroll.CanvasPosition = Vector2.new(0,0)
    end
end

