-- ================================================
-- rSPY LOG BUILDER
-- ================================================
local function addRspyLog(direction, remoteName, remotePath, args)
    if paused then return end
    if blockedRemotes[remotePath] then return end

    local filter = rspySearch.Text:lower()
    if filter ~= "" and not remoteName:lower():find(filter, 1, true) then return end

    remoteCount[remotePath] = (remoteCount[remotePath] or 0) + 1

    local isBuf = hasBuffer(args)
    local argsStr = describeArgs(args)
    local timestamp = getTime()

    local entry = {
        direction = direction,
        name = remoteName,
        path = remotePath,
        args = args,
        argsStr = argsStr,
        isBuf = isBuf,
        time = timestamp,
    }
    table.insert(remoteLogs, 1, entry)
    if #remoteLogs > maxLogs then
        table.remove(remoteLogs, #remoteLogs)
    end

    local dirColor = direction == "C\226\134\146S" and C.orange
        or direction == "S\226\134\146C" and C.blue
        or C.purple

    local order = os.clock() * 1000
    local row = mkFrame(rspyScroll,
        UDim2.new(1,-4,0,30), nil, C.panel, 3)
    row.LayoutOrder = -order

    -- Direction tag
    local dirTag = mkFrame(row,
        UDim2.new(0,32,0,18), UDim2.new(0,3,0,6), dirColor, 3)
    mkLabel(dirTag, direction,
        UDim2.new(1,0,1,0), nil,
        C.bg, 9, Enum.Font.GothamBold, Enum.TextXAlignment.Center)

    -- Buffer tag
    if isBuf then
        local bufTag = mkFrame(row,
            UDim2.new(0,24,0,14), UDim2.new(0,38,0,8), C.purple, 3)
        mkLabel(bufTag, "buf",
            UDim2.new(1,0,1,0), nil,
            C.white, 8, Enum.Font.GothamBold, Enum.TextXAlignment.Center)
    end

    local nameX = isBuf and 66 or 38

    mkLabel(row, remoteName,
        UDim2.new(0,120,0,16), UDim2.new(0,nameX,0,2),
        C.goldText, 11, Enum.Font.GothamBold)

    mkLabel(row, argsStr,
        UDim2.new(1,-nameX-130,0,14),
        UDim2.new(0,nameX+122,0,5),
        C.dim, 10, Enum.Font.Code)

    mkLabel(row, timestamp.." x"..remoteCount[remotePath],
        UDim2.new(0,70,0,14), UDim2.new(1,-72,0,5),
        C.dimDark, 9)

    -- Click handler
    local rowBtn = Instance.new("TextButton")
    rowBtn.Size = UDim2.new(1,0,1,0)
    rowBtn.BackgroundTransparency = 1
    rowBtn.Text = ""
    rowBtn.Parent = row

    rowBtn.MouseButton1Click:Connect(function()
        selectedLog = entry
        detailLabel.Text = string.format("[%s] %s | %s\n%s",
            direction, remoteName, timestamp, argsStr)
        for _, c in pairs(rspyScroll:GetChildren()) do
            if c:IsA("Frame") then c.BackgroundColor3 = C.panel end
        end
        row.BackgroundColor3 = C.goldBr
    end)

    rspyCountLabel.Text = #remoteLogs.." events"

    if rspyAutoScroll then
        rspyScroll.CanvasPosition = Vector2.new(0, 0)
    end
end

