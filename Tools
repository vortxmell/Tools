local function addRspyLog(dir, name, path, args)
    if paused then return end
    -- Direction filter
    if dirFilter == "cs" and dir ~= "C>S" then return end
    if dirFilter == "sc" and dir ~= "S>C" then return end
    local filter = rspySearch.Text:lower()
    if filter~="" and not name:lower():find(filter,1,true) then return end

    remoteCount[path] = (remoteCount[path] or 0)+1
    local isBuf   = hasBuffer(args)
    local argsStr = describeArgs(args)
    local ts      = os.date("%M:%S")
    local now     = os.clock()

    -- Cooldown: kira ms dari last fire remote yang sama
    local intervalMs = nil
    if remoteLastFire[path] then
        intervalMs = math.floor((now - remoteLastFire[path]) * 1000)
    end
    remoteLastFire[path] = now

    local entry = {
        dir=dir, name=name, path=path,
        args=args, argsStr=argsStr,
        isBuf=isBuf, time=ts,
        intervalMs=intervalMs  -- nil kalau first fire
    }
    table.insert(remoteLogs,1,entry)
    if #remoteLogs>maxLogs then table.remove(remoteLogs) end

    local dirColor = dir=="C>S" and C.orange
        or dir=="S>C" and C.blue or C.purple

    local row = mkFrame(rspyScroll,
        UDim2.new(1,-4,0,28),nil,C.panel,3)
    row.LayoutOrder = -os.clock()*1000

    local dtag = mkFrame(row,
        UDim2.new(0,30,0,16),UDim2.new(0,3,0,6),dirColor,3)
    mkLabel(dtag,dir,
        UDim2.new(1,0,1,0),nil,
        C.bg,9,Enum.Font.GothamBold,Enum.TextXAlignment.Center)

    if isBuf then
        local btag = mkFrame(row,
            UDim2.new(0,22,0,13),UDim2.new(0,36,0,8),C.purple,3)
        mkLabel(btag,"buf",
            UDim2.new(1,0,1,0),nil,
            C.white,8,Enum.Font.GothamBold,Enum.TextXAlignment.Center)
    end

    local nx = isBuf and 62 or 36
    mkLabel(row,name,
        UDim2.new(0,110,0,14),UDim2.new(0,nx,0,2),
        C.goldText,11,Enum.Font.GothamBold)
    mkLabel(row,argsStr,
        UDim2.new(1,-nx-118,0,13),
        UDim2.new(0,nx+112,0,4),
        C.dim,10,Enum.Font.Code)

    -- Bottom right: timestamp + count + interval
    local intervalStr = intervalMs and ("+"..(
        intervalMs >= 1000
        and string.format("%.1fs", intervalMs/1000)
        or intervalMs.."ms"
    )) or "first"

    -- Colour code: hijau = normal, orange = laju (<100ms), merah = sangat laju (<50ms)
    local intervalColor = C.dimDark
    if intervalMs then
        if intervalMs < 50 then
            intervalColor = C.red
        elseif intervalMs < 100 then
            intervalColor = C.orange
        else
            intervalColor = C.green
        end
    end

    mkLabel(row, ts.." x"..remoteCount[path],
        UDim2.new(0,50,0,12), UDim2.new(1,-105,0,2),
        C.dimDark, 9)
    mkLabel(row, intervalStr,
        UDim2.new(0,52,0,12), UDim2.new(1,-53,0,2),
        intervalColor, 9, Enum.Font.GothamBold)

    local rb = Instance.new("TextButton")
    rb.Size = UDim2.new(1,0,1,0)
    rb.BackgroundTransparency = 1
    rb.Text = ""
    rb.Parent = row
    rb.MouseButton1Click:Connect(function()
        selectedLog = entry
        local cooldownStr = entry.intervalMs and (
            entry.intervalMs >= 1000
            and string.format("%.2fs", entry.intervalMs/1000)
            or entry.intervalMs.."ms"
        ) or "first fire"
        detailLabel.Text = string.format(
            "[%s] %s\n%s\n\nPath:\n%s\n\nArgs:\n%s\n\nInterval: %s",
            dir, name, ts, path, argsStr, cooldownStr)
        for _,c in pairs(rspyScroll:GetChildren()) do
            if c:IsA("Frame") then c.BackgroundColor3=C.panel end
        end
        row.BackgroundColor3 = C.goldBr
    end)

    rspyCount.Text = #remoteLogs.." events"
    if rspyAutoScroll then
        rspyScroll.CanvasPosition = Vector2.new(0,0)
    end
end

