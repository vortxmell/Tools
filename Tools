-- Console log builder
local function addConLog(text, color, prefix)
    color  = color  or C.white
    prefix = prefix or ""
    local line = {text=text, color=color, prefix=prefix, time=os.date("%M:%S")}
    table.insert(logLines, line)
    if #logLines > maxLogs then table.remove(logLines,1) end

    local f   = conSearch.Text:lower()
    local row = mkFrame(conScroll,UDim2.new(1,-4,0,20),nil,C.bg)
    row.BackgroundTransparency = 1
    row.LayoutOrder = #logLines
    row.Visible     = f=="" or text:lower():find(f,1,true)~=nil

    mkLabel(row, line.time, UDim2.new(0,36,1,0), UDim2.new(0,2,0,0), C.dimDark, 9)
    if prefix~="" then
        mkLabel(row, prefix, UDim2.new(0,44,1,0), UDim2.new(0,40,0,0), color, 10, Enum.Font.GothamBold)
    end
    local tx = mkLabel(row, text,
        UDim2.new(1,-120,1,0), UDim2.new(0, prefix~="" and 88 or 44, 0, 0),
        color, 11, Enum.Font.Code)
    tx.TextWrapped = false; tx.TextTruncate = Enum.TextTruncate.AtEnd

    local cp = mkBtn(row,"⎘",UDim2.new(0,22,0,16),UDim2.new(1,-24,0,2),C.dimDark,C.goldText,10)
    cp.MouseButton1Click:Connect(function()
        copyClip(line.time.." "..prefix.." "..text)
        cp.Text = "✓"; task.delay(1, function() cp.Text = "⎘" end)
    end)

    conCount.Text = #logLines.." lines"
    if conAutoScroll then
        task.defer(function() conScroll.CanvasPosition = Vector2.new(0,math.huge) end)
    end
end

-- Execute
local function executeCode(code)
    if code=="" then return end
    local preview = code:match("([^\n]*)") or ""
    addConLog("> "..(#preview>55 and preview:sub(1,55).."..." or preview), C.goldText,"[exec]")
    local fn, err = loadstring(code)
    if fn then
        local ok, res = pcall(fn)
        addConLog(ok and (res~=nil and tostring(res) or "Done.") or tostring(res),
            ok and C.green or C.red, ok and "[ok]" or "[err]")
    else
        addConLog(tostring(err), C.red,"[err]")
    end
    if editorFullsize then toggleFullsize() end
end

runBtn.MouseButton1Click:Connect(function() executeCode(sharedCode) end)
codeInput.FocusLost:Connect(function(enter)
    if enter and not editorFullsize then executeCode(sharedCode) end
end)

