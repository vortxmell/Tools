        copyScriptBtn.Text = "Select first!"
        task.delay(1.5, function() copyScriptBtn.Text = "📋 Copy Script" end)
        return
    end

    local function buildChain(path)
        local parts = {}
        for part in path:gmatch("[^%.]+") do
            table.insert(parts, part)
        end
        if #parts == 0 then return nil end
        local chain = 'game:GetService("' .. parts[1] .. '")'
        for i = 2, #parts do
            chain = chain .. ':WaitForChild("' .. parts[i] .. '")'
        end
        return chain
    end

    local function buildArgsLines(args)
        if not args or #args == 0 then return nil end
        local out = {}
        for _, v in ipairs(args) do
            local t = type(v)
            if t == "string" then
                table.insert(out, '\t"' .. v:gsub('"', '\\"') .. '"')
            elseif t == "number" or t == "boolean" then
                table.insert(out, "\t"..tostring(v))
            elseif t == "buffer" then
                table.insert(out, "\t-- <buffer> semak Hex panel")
            else
                table.insert(out, "\t-- "..tostring(v))
            end
        end
        return out
    end

    local chain = buildChain(selectedLog.path)
    local argLines = buildArgsLines(selectedLog.args)
    local scriptLines = {}

    if chain then
        if selectedLog.dir == "C>S" then
            if argLines and #argLines > 0 then
                table.insert(scriptLines, "local args = {")
                for _, al in ipairs(argLines) do
                    table.insert(scriptLines, al..",")
                end
                table.insert(scriptLines, "}")
                table.insert(scriptLines, chain..":FireServer(unpack(args))")
            else
                table.insert(scriptLines, chain..":FireServer()")
            end
        else
            table.insert(scriptLines, "-- S>C remote, server yang fire")
            table.insert(scriptLines, chain..":OnClientEvent:Connect(function(...)")
            table.insert(scriptLines, "\tprint(...)")
            table.insert(scriptLines, "end)")
        end
    end

    copyClip(table.concat(scriptLines, "\n"))
