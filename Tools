        UDim2.new(1,0,1,-66),
        UDim2.new(0,0,0,66),
        C.bg, 0)
    content.Visible = false
    content.ClipsDescendants = true

    tabs[name] = btn
    tabContents[name] = content

    btn.MouseButton1Click:Connect(function()
        setTab(name)
    end)

    return content
end

